# ============================================================
# IPTV-BOT - Variáveis de Ambiente (copie para .env)
# ============================================================

# --- Banco de Dados PostgreSQL ---
DATABASE_URL=postgresql://iptv:iptv@db:5432/iptvbot
POSTGRES_USER=iptv
POSTGRES_PASSWORD=iptv
POSTGRES_DB=iptvbot

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- API ---
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=*

# --- Xtream Codes (opcional) ---
XTREAM_HOST=
XTREAM_USERNAME=
XTREAM_PASSWORD=

# --- Export ---
EXPORT_BASE_URL=http://localhost:8000
DEFAULT_EXPORT_PROFILE=default

# --- Logging ---
LOG_LEVEL=INFO
